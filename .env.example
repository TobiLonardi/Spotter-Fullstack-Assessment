# Copy to project root as .env and adjust:
#   copy .env.example .env   (Windows, from repo root)
#   cp .env.example .env     (Unix)

# --- Django (backend) ---
# Required in production. For local dev you can omit and use Django fallback.
SECRET_KEY=change-me-to-a-long-random-string

# true / false (default: true if unset)
DEBUG=True

# Comma-separated hostnames (no spaces after commas)
ALLOWED_HOSTS=localhost,127.0.0.1

# Browser origins allowed to call the API (CORS). Comma-separated URLs.
# Omit this variable entirely to use the default Vite dev URLs.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- OpenRouteService (backend trip routing) ---
# Free key: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
# Optional profile when ORS_BASE_URL is unset (default: driving-hgv). If ORS returns
# profile "unknown" for HGV, the backend retries once with driving-car.
# ORS_PROFILE=driving-hgv
# Optional full GeoJSON URL (overrides ORS_PROFILE).
# ORS_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-hgv/geojson

# --- Frontend (Vite; variables must be prefixed with VITE_) ---
# Optional API origin for fetch(). Leave empty for relative URLs (Vite dev proxy).
# VITE_API_URL=https://api.example.com
VITE_API_URL=